---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, tags, cover } = post.data;
const url = `/blog/${post.id}`;
---

<article class="card reveal group flex h-full flex-col overflow-hidden">
  <a href={url} class="block overflow-hidden rounded-t-[1.1rem]">
    {
      cover ? (
        <img
          src={cover}
          alt={title}
          loading="lazy"
          class="aspect-[16/9] w-full object-cover opacity-90 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
        />
      ) : (
        <div class="relative flex aspect-[16/9] w-full items-center justify-center overflow-hidden bg-gradient-to-br from-brand-700/40 via-surface to-neon-violet/20 text-2xl font-bold text-ink/90">
          <span class="relative z-10 gradient-text">{tags[0] ?? 'Web3'}</span>
          <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,rgba(130,150,255,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(130,150,255,0.08)_1px,transparent_1px)] bg-[size:28px_28px]" />
        </div>
      )
    }
  </a>
  <div class="flex flex-1 flex-col p-5">
    <div class="mb-2 flex flex-wrap gap-2">
      {
        tags.slice(0, 2).map((tag) => (
          <a href={`/tags/${tag}`} class="chip">
            {tag}
          </a>
        ))
      }
    </div>
    <a href={url} class="block">
      <h3 class="text-lg font-bold leading-snug text-ink transition-colors group-hover:text-neon-cyan">
        {title}
      </h3>
    </a>
    <p class="mt-2 line-clamp-2 flex-1 text-sm leading-relaxed text-muted">
      {description}
    </p>
    <div class="mt-4 text-xs text-slate-500">
      <FormattedDate date={pubDate} />
    </div>
  </div>
</article>
