---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  /** 序号；传入则在行首显示 #编号 */
  n?: number;
}
const { post, n } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const url = `/blog/${post.id}`;
const num = n != null ? String(n).padStart(2, '0') : null;
const dateStr = pubDate
  .toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
  .replace(/\//g, '.');
---

<a
  href={url}
  class="reveal group relative block border-b border-line px-4 py-3.5 transition-colors hover:bg-cyan/[0.04]"
>
  <span
    class="absolute left-0 top-0 h-full w-0.5 bg-transparent transition-colors group-hover:bg-cyan"
    aria-hidden="true"
  ></span>

  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[11px]">
    <time class="tabular-nums text-muted">{dateStr}</time>
    {num && <span class="text-muted">#{num}</span>}
    <span class="flex flex-wrap gap-1.5">
      {tags.slice(0, 2).map((t) => <span class="chip">{t}</span>)}
    </span>
  </div>

  <h3 class="mt-2 font-mono text-[15px] font-semibold leading-snug text-ink transition-colors group-hover:text-cyan sm:text-base">
    {title}
  </h3>
  <p class="mt-1 line-clamp-2 max-w-3xl text-[13px] leading-relaxed text-ink-soft">
    {description}
  </p>

  <span
    class="pointer-events-none absolute right-4 top-3.5 hidden font-mono text-xs text-muted transition-colors group-hover:text-cyan sm:inline"
    aria-hidden="true"
  >
    OPEN →
  </span>
</a>
