---
// 左侧终端侧栏：品牌 + 导航 + 板块分类。桌面竖排吸顶，移动端顶部横排。
import { SITE_NAME, SITE_LATIN, NAV_LINKS, CATEGORIES } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
const catActive = (tag: string) => path === `/tags/${encodeURIComponent(tag)}`;
---

<aside
  class="border-b border-line bg-panel md:sticky md:top-9 md:h-[calc(100vh-2.25rem)] md:w-60 md:shrink-0 md:overflow-y-auto md:border-b-0 md:border-r"
>
  <!-- 品牌 -->
  <a href="/" class="group flex items-center gap-2.5 border-b border-line px-4 py-3.5">
    <span class="grid h-8 w-8 place-items-center border border-up/60 font-mono text-sm font-bold text-up">
      ◧
    </span>
    <span class="leading-tight">
      <span class="block font-mono text-base font-bold text-ink">
        {SITE_NAME}<span class="up blink">_</span>
      </span>
      <span class="block font-mono text-[10px] tracking-widest text-muted">{SITE_LATIN}</span>
    </span>
  </a>

  <!-- 导航 + 板块 -->
  <nav class="flex items-stretch gap-1 overflow-x-auto px-2 py-2 font-mono text-xs md:flex-col md:gap-0 md:overflow-visible md:px-0 md:py-3">
    <div class="hidden px-4 pb-1.5 pt-1 text-[10px] uppercase tracking-widest text-muted md:block">
      // menu
    </div>
    {
      NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'shrink-0 whitespace-nowrap px-3 py-2 uppercase tracking-wider transition-colors md:px-4',
            isActive(link.href)
              ? 'text-cyan md:border-l-2 md:border-cyan md:bg-cyan/5'
              : 'text-ink-soft hover:text-cyan md:border-l-2 md:border-transparent',
          ]}
        >
          <span class="text-muted">&gt;</span> {link.label}
        </a>
      ))
    }

    <div class="mx-1 hidden border-t border-line md:my-3 md:block" />
    <div class="hidden px-4 pb-1.5 pt-1 text-[10px] uppercase tracking-widest text-muted md:block">
      // sectors
    </div>
    {
      CATEGORIES.map((tag) => (
        <a
          href={`/tags/${tag}`}
          class:list={[
            'shrink-0 whitespace-nowrap px-3 py-2 uppercase tracking-wider transition-colors md:px-4',
            catActive(tag)
              ? 'text-cyan md:border-l-2 md:border-cyan md:bg-cyan/5'
              : 'text-ink-soft hover:text-cyan md:border-l-2 md:border-transparent',
          ]}
        >
          <span class="text-up">▸</span> {tag}
        </a>
      ))
    }

    <a
      href="/rss.xml"
      class="shrink-0 whitespace-nowrap px-3 py-2 uppercase tracking-wider text-muted transition-colors hover:text-cyan md:mt-1 md:border-l-2 md:border-transparent md:px-4"
    >
      <span class="text-muted">&gt;</span> RSS
    </a>
  </nav>
</aside>
