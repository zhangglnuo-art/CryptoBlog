---
import { SITE_NAME, SITE_LATIN, NAV_LINKS } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
const today = new Date().toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<header class="bg-paper">
  <!-- 顶部行：定位 + 日期，等宽小型大写 -->
  <div class="mx-auto max-w-5xl px-4">
    <div class="flex items-center justify-between border-b border-line py-2.5 font-mono text-[11px] uppercase tracking-[0.2em] text-muted">
      <span>加密货币 · Web3 · 独立阅读</span>
      <span class="hidden sm:inline">{today}</span>
    </div>

    <!-- 报头：大衬线刊名 -->
    <div class="py-9 text-center sm:py-12">
      <a href="/" class="inline-block">
        <h1 class="font-serif text-6xl font-semibold leading-none tracking-tight text-ink sm:text-7xl">
          {SITE_NAME}
        </h1>
      </a>
      <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.4em] text-accent">
        {SITE_LATIN}
      </p>
    </div>
  </div>

  <!-- 导航：细长条，双线上边框，滚动时吸顶 -->
  <nav class="sticky top-0 z-40 border-y border-double border-t-[3px] border-ink bg-paper/95 backdrop-blur-sm">
    <div class="mx-auto flex max-w-5xl items-center justify-center gap-7 px-4 py-3 font-mono text-xs uppercase tracking-[0.18em]">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'transition-colors',
              isActive(link.href) ? 'text-accent' : 'text-ink hover:text-accent',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/rss.xml"
        class="text-muted transition-colors hover:text-accent"
        aria-label="RSS 订阅"
      >
        RSS
      </a>
    </div>
  </nav>
</header>
