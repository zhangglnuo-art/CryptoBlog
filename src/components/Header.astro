---
import { SITE_TITLE, NAV_LINKS } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-white/5 bg-void/60 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4">
    <a href="/" class="group flex items-center gap-2.5 font-bold text-ink">
      <span
        class="relative grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-neon-cyan via-brand-500 to-neon-violet text-base font-black text-void shadow-[0_0_20px_-2px_rgba(47,230,255,0.7)] transition-shadow group-hover:shadow-[0_0_28px_0_rgba(47,230,255,0.9)]"
      >
        链
      </span>
      <span class="text-lg tracking-tight">{SITE_TITLE}</span>
    </a>

    <div class="flex items-center gap-1">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'text-neon-cyan'
                : 'text-slate-300 hover:text-neon-cyan',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/rss.xml"
        title="RSS 订阅"
        class="ml-1 rounded-lg p-2 text-slate-500 transition-colors hover:text-neon-cyan"
        aria-label="RSS 订阅"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36ZM4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44Zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>
