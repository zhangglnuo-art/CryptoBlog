---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ArticleRow from '../components/ArticleRow.astro';
import { SITE_URL, SITE_TITLE } from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: MarkdownHeading[];
}
const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, author, cover } =
  post.data;

const url = new URL(`/blog/${post.id}`, SITE_URL).toString();

// 相关文章：共享标签、按日期倒序取 3 篇（站内互链，利于 SEO 与停留时长）
const all = await getCollection('blog', ({ data }) => !data.draft);
const related = all
  .filter((p) => p.id !== post.id && p.data.tags.some((t) => tags.includes(t)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Article 结构化数据 —— 让 Google 更好地理解并可能给富摘要
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    author: { '@type': 'Organization', name: author },
    publisher: { '@type': 'Organization', name: SITE_TITLE },
    mainEntityOfPage: url,
    ...(cover ? { image: new URL(cover, SITE_URL).toString() } : {}),
    keywords: tags.join(', '),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首页', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: '博客', item: `${SITE_URL}/blog` },
      { '@type': 'ListItem', position: 3, name: title, item: url },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate ?? pubDate}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-2xl px-4 py-12">
    <!-- 面包屑 -->
    <nav class="mb-8 font-mono text-[11px] uppercase tracking-[0.16em] text-muted" aria-label="面包屑">
      <a href="/" class="transition-colors hover:text-accent">首页</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="transition-colors hover:text-accent">文章</a>
    </nav>

    <header>
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        {tags.map((tag) => <a href={`/tags/${tag}`} class="tag">{tag}</a>)}
      </div>
      <h1 class="mt-4 font-serif text-4xl font-semibold leading-[1.12] tracking-tight text-ink sm:text-5xl">
        {title}
      </h1>
      <p class="mt-5 font-serif text-xl leading-relaxed text-ink-soft">
        {description}
      </p>
      <div class="mt-7 flex items-center gap-3 border-y border-line py-3 font-mono text-[11px] uppercase tracking-[0.16em] text-muted">
        <span class="text-ink">{author}</span>
        <span>—</span>
        <FormattedDate date={pubDate} />
        {updatedDate && (<><span>·</span><span>更新 <FormattedDate date={updatedDate} /></span></>)}
      </div>
      {
        cover && (
          <img
            src={cover}
            alt={title}
            class="mt-8 aspect-[2/1] w-full border border-ink object-cover"
          />
        )
      }
    </header>

    <!-- 正文（首字下沉由 .article-body 触发） -->
    <div class="article-body prose prose-lg mt-10">
      <slot />
    </div>

    <!-- 文末：相关阅读 -->
    {
      related.length > 0 && (
        <section class="mt-16">
          <h2 class="kicker mb-2">延伸阅读 / Related</h2>
          <div class="border-t-2 border-ink">
            {related.map((p) => <ArticleRow post={p} />)}
          </div>
        </section>
      )
    }

    <div class="mt-14 text-center">
      <a href="/blog" class="btn-outline">← 回到文章目录</a>
    </div>
  </article>
</BaseLayout>
