---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_URL, SITE_TITLE } from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: MarkdownHeading[];
}
const { post, headings } = Astro.props;
const { title, description, pubDate, updatedDate, tags, author, cover } =
  post.data;

// 只取 h2/h3 做目录，太深的层级对读者没意义
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const url = new URL(`/blog/${post.id}`, SITE_URL).toString();

// Article 结构化数据 —— 让 Google 更好地理解并可能给富摘要
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    author: { '@type': 'Organization', name: author },
    publisher: { '@type': 'Organization', name: SITE_TITLE },
    mainEntityOfPage: url,
    ...(cover ? { image: new URL(cover, SITE_URL).toString() } : {}),
    keywords: tags.join(', '),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首页', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: '博客', item: `${SITE_URL}/blog` },
      { '@type': 'ListItem', position: 3, name: title, item: url },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate ?? pubDate}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-6xl px-4 py-10">
    <!-- 面包屑 -->
    <nav class="mb-6 text-sm text-muted" aria-label="面包屑">
      <a href="/" class="hover:text-neon-cyan">首页</a>
      <span class="mx-1.5">/</span>
      <a href="/blog" class="hover:text-neon-cyan">博客</a>
      <span class="mx-1.5">/</span>
      <span class="text-slate-500">{title}</span>
    </nav>

    <header class="mb-8">
      <div class="mb-3 flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <a href={`/tags/${tag}`} class="chip">
              {tag}
            </a>
          ))
        }
      </div>
      <h1 class="text-3xl font-extrabold leading-tight text-ink sm:text-4xl">
        {title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">{description}</p>
      {
        cover && (
          <img
            src={cover}
            alt={title}
            class="mt-6 aspect-[2/1] w-full rounded-2xl border border-white/10 object-cover shadow-[0_20px_60px_-20px_rgba(47,230,255,0.25)]"
          />
        )
      }
      <div class="mt-5 flex items-center gap-3 text-sm text-slate-500">
        <span>{author}</span>
        <span>·</span>
        <FormattedDate date={pubDate} />
        {updatedDate && <><span>·</span><span>更新于 <FormattedDate date={updatedDate} /></span></>}
      </div>
    </header>

    <div class="gap-10 lg:grid lg:grid-cols-[1fr_260px]">
      <!-- 正文 -->
      <div class="prose prose-lg min-w-0">
        <slot />
      </div>

      <!-- 目录（桌面端 sticky） -->
      {
        toc.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24">
              <p class="eyebrow mb-3">本文目录</p>
              <ul class="space-y-2 border-l border-white/10 text-sm">
                {toc.map((h) => (
                  <li class={h.depth === 3 ? 'pl-4' : ''}>
                    <a
                      href={`#${h.slug}`}
                      class="-ml-px block border-l-2 border-transparent pl-3 text-muted transition-colors hover:border-neon-cyan hover:text-neon-cyan"
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )
      }
    </div>
  </article>
</BaseLayout>
