---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ArticleRow from '../components/ArticleRow.astro';
import { SITE_URL, SITE_TITLE } from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: MarkdownHeading[];
}
const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, author, cover } =
  post.data;

const url = new URL(`/blog/${post.id}`, SITE_URL).toString();

// 相关文章：共享标签、按日期倒序取 3 篇（站内互链）
const all = await getCollection('blog', ({ data }) => !data.draft);
const related = all
  .filter((p) => p.id !== post.id && p.data.tags.some((t) => tags.includes(t)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    author: { '@type': 'Organization', name: author },
    publisher: { '@type': 'Organization', name: SITE_TITLE },
    mainEntityOfPage: url,
    ...(cover ? { image: new URL(cover, SITE_URL).toString() } : {}),
    keywords: tags.join(', '),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首页', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: '博客', item: `${SITE_URL}/blog` },
      { '@type': 'ListItem', position: 3, name: title, item: url },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate ?? pubDate}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-3xl px-4 py-6">
    <!-- 路径面包屑 -->
    <nav class="font-mono text-xs text-muted" aria-label="面包屑">
      <a href="/" class="transition-colors hover:text-cyan">~</a>
      <span class="text-line">/</span>
      <a href="/blog" class="transition-colors hover:text-cyan">blog</a>
      <span class="text-line">/</span>
      <span class="text-cyan">{post.id}</span>
    </nav>

    <article class="panel mt-4">
      <div class="panel-head">
        <span class="flex flex-wrap gap-1.5">
          {tags.map((tag) => <a href={`/tags/${tag}`} class="chip">{tag}</a>)}
        </span>
        <span class="text-muted"><FormattedDate date={pubDate} /></span>
      </div>

      <div class="p-5 sm:p-8">
        <header>
          <h1 class="font-mono text-3xl font-bold leading-tight text-ink sm:text-4xl">
            {title}
          </h1>
          <p class="mt-4 text-lg leading-relaxed text-ink-soft">{description}</p>
          <div class="mt-5 flex flex-wrap items-center gap-2 border-t border-line pt-4 font-mono text-[11px] uppercase tracking-wider text-muted">
            <span class="text-ink-soft">{author}</span>
            <span class="text-line">|</span>
            <FormattedDate date={pubDate} />
            {updatedDate && (<><span class="text-line">|</span><span>updated <FormattedDate date={updatedDate} /></span></>)}
          </div>
          {
            cover && (
              <img
                src={cover}
                alt={title}
                class="mt-6 aspect-[2/1] w-full border border-line object-cover"
              />
            )
          }
        </header>

        <div class="prose prose-lg mt-8">
          <slot />
        </div>
      </div>
    </article>

    {
      related.length > 0 && (
        <section class="panel mt-6">
          <div class="panel-head"><span>Related // 延伸阅读</span></div>
          <div>{related.map((p) => <ArticleRow post={p} />)}</div>
        </section>
      )
    }

    <div class="mt-8 text-center">
      <a href="/blog" class="btn-ghost">← 回到信息流</a>
    </div>
  </div>
</BaseLayout>
