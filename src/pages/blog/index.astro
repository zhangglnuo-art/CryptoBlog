---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleRow from '../../components/ArticleRow.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const tagCount = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) tagCount.set(t, (tagCount.get(t) ?? 0) + 1);
}
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="全部文章"
  description="区块链与加密货币科普合集：跨链桥、跨链兑换、DEX、稳定币、DeFi 与钱包安全的全部图文教程。"
>
  <div class="mx-auto max-w-5xl px-4 py-6">
    <div class="reveal font-mono text-xs text-muted">~/blog</div>
    <h1 class="reveal mt-2 font-mono text-3xl font-bold text-ink sm:text-4xl">
      全部文章 <span class="text-muted">[{posts.length}]</span>
    </h1>

    {
      tags.length > 0 && (
        <div class="reveal mt-5 flex flex-wrap gap-1.5">
          {tags.map(([tag, count]) => (
            <a href={`/tags/${tag}`} class="chip">
              {tag}·{count}
            </a>
          ))}
        </div>
      )
    }

    <section class="panel mt-6">
      <div class="panel-head">
        <span>Feed // 全部</span>
        <span class="text-muted">sort: newest</span>
      </div>
      <div>
        {posts.map((post, i) => <ArticleRow post={post} n={i + 1} />)}
      </div>
    </section>
  </div>
</BaseLayout>
