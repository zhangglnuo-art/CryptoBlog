---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleRow from '../../components/ArticleRow.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 收集所有标签做筛选入口
const tagCount = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) tagCount.set(t, (tagCount.get(t) ?? 0) + 1);
}
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="全部文章"
  description="区块链与加密货币科普合集：跨链桥、跨链兑换、DEX、稳定币、DeFi 与钱包安全的全部图文教程。"
>
  <div class="mx-auto max-w-5xl px-4 py-14">
    <header class="reveal border-b-2 border-ink pb-6">
      <p class="kicker">Archive / 全部文章</p>
      <h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight text-ink sm:text-6xl">
        文章目录
      </h1>
      <p class="mt-3 font-mono text-xs uppercase tracking-[0.16em] text-muted">
        共 {posts.length} 篇 · 区块链原理、链上实操与安全经验
      </p>
    </header>

    {
      tags.length > 0 && (
        <div class="reveal flex flex-wrap items-center gap-x-5 gap-y-2 border-b border-line py-4">
          {tags.map(([tag, count]) => (
            <a href={`/tags/${tag}`} class="tag">
              {tag} <span class="text-muted">·{count}</span>
            </a>
          ))}
        </div>
      )
    }

    <div class="mt-2">
      {posts.map((post, i) => <ArticleRow post={post} n={i + 1} />)}
    </div>
  </div>
</BaseLayout>
