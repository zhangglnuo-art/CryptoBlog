---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <div class="mx-auto max-w-xl px-4 py-28 text-center">
    <p class="text-7xl font-extrabold gradient-text">404</p>
    <h1 class="mt-4 text-2xl font-bold text-ink">这个页面走丢了</h1>
    <p class="mt-2 text-muted">链接可能已失效，或文章尚未发布。</p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/" class="btn-glow">回首页</a>
      <a href="/blog" class="btn-ghost">看全部文章</a>
    </div>
  </div>
</BaseLayout>
