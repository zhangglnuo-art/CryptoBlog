---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleRow from '../components/ArticleRow.astro';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const lead = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== lead?.id);

const topicCount = new Set(posts.flatMap((p) => p.data.tags)).size;
const latest = posts[0];
---

<BaseLayout>
  <div class="mx-auto max-w-5xl px-4 py-6">
    <!-- 状态栏 stat tiles -->
    <div class="reveal grid grid-cols-2 gap-px overflow-hidden border border-line bg-line sm:grid-cols-4">
      <div class="bg-panel px-4 py-3">
        <div class="font-mono text-[10px] uppercase tracking-widest text-muted">Posts</div>
        <div class="mt-1 font-mono text-2xl font-bold text-ink">{posts.length}</div>
      </div>
      <div class="bg-panel px-4 py-3">
        <div class="font-mono text-[10px] uppercase tracking-widest text-muted">Sectors</div>
        <div class="mt-1 font-mono text-2xl font-bold text-ink">{topicCount}</div>
      </div>
      <div class="bg-panel px-4 py-3">
        <div class="font-mono text-[10px] uppercase tracking-widest text-muted">Last Update</div>
        <div class="mt-1 font-mono text-sm font-bold text-cyan">
          {latest && <FormattedDate date={latest.data.pubDate} />}
        </div>
      </div>
      <div class="bg-panel px-4 py-3">
        <div class="font-mono text-[10px] uppercase tracking-widest text-muted">Status</div>
        <div class="mt-1 font-mono text-sm font-bold"><span class="up">●</span> <span class="up">SYNCED</span></div>
      </div>
    </div>

    <!-- 头条面板 -->
    {
      lead && (
        <section class="reveal panel mt-6">
          <div class="panel-head">
            <span>▲ Featured // 头条</span>
            <span class="text-muted">{lead.data.tags[0]}</span>
          </div>
          <a href={`/blog/${lead.id}`} class="group block p-5 sm:p-7">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[11px]">
              <span class="flex flex-wrap gap-1.5">
                {lead.data.tags.map((t) => <span class="chip">{t}</span>)}
              </span>
              <span class="text-muted"><FormattedDate date={lead.data.pubDate} /></span>
            </div>
            <h2 class="mt-4 font-mono text-2xl font-bold leading-tight text-ink transition-colors group-hover:text-cyan sm:text-4xl">
              {lead.data.title}
            </h2>
            <p class="mt-4 max-w-2xl text-[15px] leading-relaxed text-ink-soft">
              {lead.data.description}
            </p>
            <span class="mt-5 inline-flex font-mono text-xs font-semibold uppercase tracking-wider text-cyan">
              OPEN_ARTICLE →
            </span>
          </a>
        </section>
      )
    }

    <!-- 信息流 -->
    <section class="panel mt-6">
      <div class="panel-head">
        <span>Feed // 最新文章</span>
        <a href="/blog" class="text-muted transition-colors hover:text-cyan">ALL →</a>
      </div>
      <div>
        {rest.map((post, i) => <ArticleRow post={post} n={i + 1} />)}
      </div>
    </section>
  </div>
</BaseLayout>
