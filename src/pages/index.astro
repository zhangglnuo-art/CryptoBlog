---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleRow from '../components/ArticleRow.astro';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const lead = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== lead?.id);

const sections = ['跨链桥', '跨链兑换', 'DEX', '稳定币', 'DeFi', '钱包安全'];
---

<BaseLayout>
  <!-- 头条（Lead）：一篇大标题占版，编辑风 -->
  {
    lead && (
      <section class="mx-auto max-w-5xl px-4 pt-12 pb-10 sm:pt-16">
        <p class="kicker reveal">本期头条 — {lead.data.tags[0]}</p>
        <a href={`/blog/${lead.id}`} class="reveal group mt-5 block">
          <h2 class="font-serif text-[2.6rem] font-semibold leading-[1.05] tracking-tight text-ink transition-colors group-hover:text-accent sm:text-6xl lg:text-7xl">
            {lead.data.title}
          </h2>
        </a>
        <div class="reveal mt-8 grid gap-6 border-t border-line pt-6 md:grid-cols-[1fr_14rem] md:gap-12">
          <p class="max-w-2xl font-serif text-xl leading-relaxed text-ink-soft sm:text-2xl">
            {lead.data.description}
          </p>
          <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-muted md:text-right">
            <div>{lead.data.author}</div>
            <div class="mt-1"><FormattedDate date={lead.data.pubDate} /></div>
            <a
              href={`/blog/${lead.id}`}
              class="mt-4 inline-block text-accent transition-colors hover:text-ink"
            >
              阅读全文 →
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- 栏目导览 -->
  <section class="mx-auto max-w-5xl px-4 pb-2">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 border-y border-line py-3 font-mono text-[11px] uppercase tracking-[0.16em] text-muted">
      <span class="text-ink">栏目 /</span>
      {
        sections.map((s) => (
          <a href={`/tags/${s}`} class="transition-colors hover:text-accent">
            {s}
          </a>
        ))
      }
    </div>
  </section>

  <!-- 最新文章：编号索引 -->
  <section class="mx-auto max-w-5xl px-4 pb-24 pt-10">
    <div class="mb-2 flex items-baseline justify-between border-b-2 border-ink pb-3">
      <h3 class="font-serif text-2xl font-semibold text-ink">最新文章</h3>
      <a href="/blog" class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink transition-colors hover:text-accent">全部 →</a>
    </div>
    <div>
      {rest.map((post, i) => <ArticleRow post={post} n={i + 1} />)}
    </div>
  </section>
</BaseLayout>
