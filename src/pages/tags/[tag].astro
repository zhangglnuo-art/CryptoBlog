---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleRow from '../../components/ArticleRow.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`${tag} 相关文章`}
  description={`与「${tag}」相关的区块链与加密货币科普文章，共 ${posts.length} 篇。`}
>
  <div class="mx-auto max-w-5xl px-4 py-6">
    <div class="reveal font-mono text-xs text-muted">
      ~/tags/<span class="text-cyan">{tag}</span>
    </div>
    <h1 class="reveal mt-2 font-mono text-3xl font-bold text-ink sm:text-4xl">
      <span class="text-up">▸</span> {tag} <span class="text-muted">[{posts.length}]</span>
    </h1>
    <a href="/blog" class="reveal mt-3 inline-block font-mono text-xs uppercase tracking-wider text-cyan transition-colors hover:text-ink">
      ← 全部文章
    </a>

    <section class="panel mt-6">
      <div class="panel-head">
        <span>Feed // {tag}</span>
        <span class="text-muted">sort: newest</span>
      </div>
      <div>
        {posts.map((post, i) => <ArticleRow post={post} n={i + 1} />)}
      </div>
    </section>
  </div>
</BaseLayout>
