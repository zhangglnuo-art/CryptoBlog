---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleRow from '../../components/ArticleRow.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`${tag} 相关文章`}
  description={`与「${tag}」相关的区块链与加密货币科普文章，共 ${posts.length} 篇。`}
>
  <div class="mx-auto max-w-5xl px-4 py-14">
    <header class="reveal border-b-2 border-ink pb-6">
      <a href="/blog" class="font-mono text-[11px] uppercase tracking-[0.16em] text-accent transition-colors hover:text-ink">
        ← 全部文章
      </a>
      <p class="kicker mt-4">栏目 / Section</p>
      <h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight text-ink sm:text-6xl">
        {tag}
      </h1>
      <p class="mt-3 font-mono text-xs uppercase tracking-[0.16em] text-muted">
        共 {posts.length} 篇
      </p>
    </header>

    <div class="mt-2">
      {posts.map((post, i) => <ArticleRow post={post} n={i + 1} />)}
    </div>
  </div>
</BaseLayout>
